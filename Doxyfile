# Doxygen configuration for harookie Unity GameKit.
# Run from the package root with: doxygen Doxyfile

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "harookie Unity GameKit"
PROJECT_NUMBER         = 0.1.1
PROJECT_BRIEF          = "Reusable Unity gameplay infrastructure and UI helpers."

# Keep generated documentation inside Unity's documentation-only folder.
OUTPUT_DIRECTORY       = Documentation~/api
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

# Treat C# declarations as the primary API and include undocumented public API.
OPTIMIZE_OUTPUT_JAVA   = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = NO

# Sources and hand-written guides.
INPUT                   = README.md \
                          Documentation~ \
                          Runtime \
                          Editor
FILE_PATTERNS            = *.cs \
                           *.md
RECURSIVE                = YES
EXCLUDE                  = Documentation~/api
EXCLUDE_PATTERNS         = */.git/* \
                           */Library/* \
                           */Temp/* \
                           */Obj/* \
                           */Build/* \
                           */Builds/* \
                           */Logs/* \
                           */UserSettings/*
USE_MDFILE_AS_MAINPAGE   = README.md

# C# XML documentation comments and Markdown are understood automatically.
MARKDOWN_SUPPORT         = YES
AUTOLINK_SUPPORT         = YES
BUILTIN_STL_SUPPORT      = YES
TOC_INCLUDE_HEADINGS     = 5

# Make source locations browsable without embedding complete source files.
SOURCE_BROWSER           = YES
INLINE_SOURCES           = NO
STRIP_CODE_COMMENTS      = YES
REFERENCED_BY_RELATION   = YES
REFERENCES_RELATION      = YES
STRIP_FROM_PATH          = .

# Diagnostics: warn about malformed docs, but not every currently-undocumented API.
QUIET                    = NO
WARNINGS                 = YES
WARN_IF_UNDOCUMENTED     = NO
WARN_IF_DOC_ERROR        = YES
WARN_IF_INCOMPLETE_DOC   = YES
WARN_NO_PARAMDOC         = NO
WARN_FORMAT              = "$file:$line: $text"
WARN_LOGFILE             =

# Searchable HTML is the distributable documentation format.
GENERATE_HTML            = YES
HTML_OUTPUT              = html
HTML_FILE_EXTENSION      = .html
HTML_COLORSTYLE          = AUTO_LIGHT
GENERATE_TREEVIEW        = YES
DISABLE_INDEX            = NO
FULL_SIDEBAR             = NO
SEARCHENGINE             = YES
SERVER_BASED_SEARCH      = NO

# Disable formats and optional external tooling that are not needed by default.
GENERATE_LATEX           = NO
GENERATE_RTF             = NO
GENERATE_MAN             = NO
GENERATE_XML             = NO
GENERATE_DOCBOOK         = NO
GENERATE_SQLITE3         = NO
GENERATE_PERLMOD         = NO
HAVE_DOT                 = NO
CALL_GRAPH               = NO
CALLER_GRAPH             = NO
